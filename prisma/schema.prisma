generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       String @id @default(cuid(2))
  username String
  email    String
  posts    Post[]
}

model Post {
  id        String  @id @default(cuid(2))
  title     String
  content   String
  published Boolean @default(false)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
}
